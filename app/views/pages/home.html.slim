nav.bg-stone-800.text-white.py-4
  .container.mx-auto.px-4.flex.justify-between.items-center
    = link_to root_path, class: "flex.items-center.gap-3"
      .w-10.h-10.bg-red-700.rounded-full
      div
        .text-xl Владимир
        /.text-sm.text-stone-400 Веб-разработчик

    .flex.gap-4
      = link_to "Проекты", projects_path, class: "hover:text-red-400"

section.bg-stone-700.text-white.py-40
  .container.mx-auto.px-4.text-center
    h1.text-4xl.font-bold.mb-4 Веб разработка любой сложности
    p.text-xl.text-stone-300 От идеи до запуска и развития

section.bg-neutral-300.text-black.py-3
  .container.mx-auto.px-4.text-center
    h1.text-xl.font-bold.mb-2 Для кого: бизнесмена, предпринемателя, директора, руководителя любого уровня

